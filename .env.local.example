# ---- Google Gemini — answers + embeddings (free tier, no card) ----
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=...

# Optional: override the generation model (default gemini-2.5-flash).
# CHAT_MODEL=gemini-2.5-flash-lite

# ---- Supabase — Postgres + pgvector (vector store) ----
# Create a project at https://supabase.com, then Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
