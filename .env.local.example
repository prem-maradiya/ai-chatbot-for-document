# ---- Anthropic (Claude) — answer generation ----
# Get a key (with free trial credits) at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: stretch free trial credits by using the cheapest model.
# Defaults to claude-opus-4-8. Uncomment the next line to use Haiku instead:
# CHAT_MODEL=claude-haiku-4-5

# ---- Voyage AI — embeddings (free tier: 200M tokens, no card) ----
# Get a key at https://www.voyageai.com  (Dashboard > API Keys)
VOYAGE_API_KEY=pa-...

# ---- Supabase — Postgres + pgvector (vector store) ----
# Create a project at https://supabase.com, then Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
